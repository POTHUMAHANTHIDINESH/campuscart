# Copy this file to .env and fill in your real values

# Get this from MongoDB Atlas (free tier) -> Connect -> Drivers -> copy connection string
MONGO_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/campus-marketplace

# Any long random string, used to sign login tokens. Just make one up.
JWT_SECRET=replace_this_with_a_long_random_string

# Get these free from https://dashboard.razorpay.com (Test Mode -> API Keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_test_secret

# Port the backend server runs on
PORT=5000
